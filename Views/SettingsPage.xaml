<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LocalAIAssistant.Views.SettingsPage"
             Title="Settings">

    <ScrollView Padding="0,8">
        <VerticalStackLayout Spacing="0">

            <!-- ═══════════════════════════════════════════ -->
            <!-- Section: Connection                         -->
            <!-- ═══════════════════════════════════════════ -->
            <Label Text="CONNECTION"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="{StaticResource SecondaryTextColor}"
                   Margin="20,16,20,6"
                   CharacterSpacing="1.5" />

            <Border Margin="12,0"
                    Padding="16"
                    StrokeThickness="0"
                    BackgroundColor="{StaticResource SurfaceColor}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">

                    <Label Text="Environment"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="{StaticResource PrimaryTextColor}" />
                    <Picker Title="Select Environment"
                            ItemsSource="{Binding Environments}"
                            SelectedItem="{Binding SelectedEnvironment}" />

                    <BoxView HeightRequest="1"
                             BackgroundColor="{StaticResource SurfaceAltColor}"
                             Margin="0,4" />

                    <Label Text="Ollama Endpoint"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="{StaticResource PrimaryTextColor}" />
                    <Entry Text="{Binding Endpoint}"
                           Placeholder="http://localhost:11434" />

                </VerticalStackLayout>
            </Border>

            <!-- ═══════════════════════════════════════════ -->
            <!-- Section: Model                              -->
            <!-- ═══════════════════════════════════════════ -->
            <Label Text="MODEL"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="{StaticResource SecondaryTextColor}"
                   Margin="20,20,20,6"
                   CharacterSpacing="1.5" />

            <Border Margin="12,0"
                    Padding="16"
                    StrokeThickness="0"
                    BackgroundColor="{StaticResource SurfaceColor}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">

                    <Label Text="Model name"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="{StaticResource PrimaryTextColor}" />
                    <Entry Text="{Binding Model}"
                           Placeholder="e.g. deepseek-coder:6.7b" />

                    <BoxView HeightRequest="1"
                             BackgroundColor="{StaticResource SurfaceAltColor}"
                             Margin="0,4" />

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Text="Max tokens (num_predict)"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{StaticResource PrimaryTextColor}"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="{Binding NumPredict}"
                               FontSize="13"
                               TextColor="{StaticResource SecondaryTextColor}"
                               VerticalOptions="Center" />
                    </Grid>
                    <Slider Minimum="1"
                            Maximum="2048"
                            Value="{Binding NumPredict, Mode=TwoWay}" />

                    <BoxView HeightRequest="1"
                             BackgroundColor="{StaticResource SurfaceAltColor}"
                             Margin="0,4" />

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Text="Temperature"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{StaticResource PrimaryTextColor}"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="{Binding Temperature, StringFormat='{0:F2}'}"
                               FontSize="13"
                               TextColor="{StaticResource SecondaryTextColor}"
                               VerticalOptions="Center" />
                    </Grid>
                    <Slider Minimum="0"
                            Maximum="1"
                            Value="{Binding Temperature, Mode=TwoWay}" />
                    <Label Text="Lower = more precise. Higher = more creative."
                           FontSize="11"
                           TextColor="{StaticResource SecondaryTextColor}" />

                </VerticalStackLayout>
            </Border>

            <!-- ═══════════════════════════════════════════ -->
            <!-- Section: Personality (coming soon)          -->
            <!-- ═══════════════════════════════════════════ -->
            <Label Text="PERSONALITY"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="{StaticResource SecondaryTextColor}"
                   Margin="20,20,20,6"
                   CharacterSpacing="1.5" />

            <Border Margin="12,0"
                    Padding="16"
                    StrokeThickness="0"
                    BackgroundColor="{StaticResource SurfaceColor}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Personalities not yet configured."
                           FontSize="13"
                           TextColor="{StaticResource SecondaryTextColor}" />
                    <Label Text="ENH-10 / EPIC-05 will add a personality picker here once the JSON catalog is wired up."
                           FontSize="11"
                           TextColor="{StaticResource SecondaryTextColor}" />
                    <Button Text="Apply Personality Settings"
                            Command="{Binding ApplyPersonalityCommand}"
                            Margin="0,4,0,0" />
                </VerticalStackLayout>
            </Border>

            <!-- ═══════════════════════════════════════════ -->
            <!-- Save                                        -->
            <!-- ═══════════════════════════════════════════ -->
            <Button Text="Save"
                    Command="{Binding SaveCommand}"
                    Margin="12,20,12,4"
                    HeightRequest="48" />

            <Label Text="Applies Ollama connection and model settings."
                   FontSize="11"
                   TextColor="{StaticResource SecondaryTextColor}"
                   HorizontalOptions="Center"
                   Margin="0,4,0,24" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LocalAIAssistant.Views.SettingsPage"
             Title="Settings">

    <ScrollView Padding="0,8">
        <VerticalStackLayout Spacing="0">

            <!-- ═══════════════════════════════════════════ -->
            <!-- Section: Connection                         -->
            <!-- ═══════════════════════════════════════════ -->
            <Label Text="CONNECTION"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="{StaticResource SecondaryTextColor}"
                   Margin="20,16,20,6"
                   CharacterSpacing="1.5" />

            <Border Margin="12,0"
                    Padding="16"
                    StrokeThickness="0"
                    BackgroundColor="{StaticResource SurfaceColor}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">

                    <Label Text="Environment"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="{StaticResource PrimaryTextColor}" />
                    <Picker Title="Select Environment"
                            ItemsSource="{Binding Environments}"
                            SelectedItem="{Binding SelectedEnvironment}" />

                    <BoxView HeightRequest="1"
                             BackgroundColor="{StaticResource SurfaceAltColor}"
                             Margin="0,4" />

                    <Label Text="Ollama Endpoint"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="{StaticResource PrimaryTextColor}" />
                    <Entry Text="{Binding Endpoint}"
                           Placeholder="http://localhost:11434" />

                </VerticalStackLayout>
            </Border>

            <!-- ═══════════════════════════════════════════ -->
            <!-- Section: Model                              -->
            <!-- ═══════════════════════════════════════════ -->
            <Label Text="MODEL"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="{StaticResource SecondaryTextColor}"
                   Margin="20,20,20,6"
                   CharacterSpacing="1.5" />

            <Border Margin="12,0"
                    Padding="16"
                    StrokeThickness="0"
                    BackgroundColor="{StaticResource SurfaceColor}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">

                    <Label Text="Model name"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="{StaticResource PrimaryTextColor}" />
                    <Entry Text="{Binding Model}"
                           Placeholder="e.g. deepseek-coder:6.7b" />

                    <BoxView HeightRequest="1"
                             BackgroundColor="{StaticResource SurfaceAltColor}"
                             Margin="0,4" />

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Text="Max tokens (num_predict)"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{StaticResource PrimaryTextColor}"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="{Binding NumPredict}"
                               FontSize="13"
                               TextColor="{StaticResource SecondaryTextColor}"
                               VerticalOptions="Center" />
                    </Grid>
                    <Slider Minimum="1"
                            Maximum="2048"
                            Value="{Binding NumPredict, Mode=TwoWay}" />

                    <BoxView HeightRequest="1"
                             BackgroundColor="{StaticResource SurfaceAltColor}"
                             Margin="0,4" />

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Text="Temperature"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{StaticResource PrimaryTextColor}"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="{Binding Temperature, StringFormat='{0:F2}'}"
                               FontSize="13"
                               TextColor="{StaticResource SecondaryTextColor}"
                               VerticalOptions="Center" />
                    </Grid>
                    <Slider Minimum="0"
                            Maximum="1"
                            Value="{Binding Temperature, Mode=TwoWay}" />
                    <Label Text="Lower = more precise. Higher = more creative."
                           FontSize="11"
                           TextColor="{StaticResource SecondaryTextColor}" />

                </VerticalStackLayout>
            </Border>

            <!-- ═══════════════════════════════════════════ -->
            <!-- Section: Personality (coming soon)          -->
            <!-- ═══════════════════════════════════════════ -->
            <Label Text="PERSONALITY"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="{StaticResource SecondaryTextColor}"
                   Margin="20,20,20,6"
                   CharacterSpacing="1.5" />

            <Border Margin="12,0"
                    Padding="16"
                    StrokeThickness="0"
                    BackgroundColor="{StaticResource SurfaceColor}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Personalities not yet configured."
                           FontSize="13"
                           TextColor="{StaticResource SecondaryTextColor}" />
                    <Label Text="ENH-10 / EPIC-05 will add a personality picker here once the JSON catalog is wired up."
                           FontSize="11"
                           TextColor="{StaticResource SecondaryTextColor}" />
                    <Button Text="Apply Personality Settings"
                            Command="{Binding ApplyPersonalityCommand}"
                            Margin="0,4,0,0" />
                </VerticalStackLayout>
            </Border>

            <!-- ═══════════════════════════════════════════ -->
            <!-- Section: Text-to-Speech                     -->
            <!-- ═══════════════════════════════════════════ -->
            <Label Text="TEXT-TO-SPEECH"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="{StaticResource SecondaryTextColor}"
                   Margin="20,20,20,6"
                   CharacterSpacing="1.5" />

            <Border Margin="12,0"
                    Padding="16"
                    StrokeThickness="0"
                    BackgroundColor="{StaticResource SurfaceColor}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">

                    <Label Text="Provider"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="{StaticResource PrimaryTextColor}" />
                    <Picker Title="Select provider"
                            ItemsSource="{Binding TtsProviders}"
                            SelectedItem="{Binding SelectedTtsProvider}" />

                    <!-- Azure settings -->
                    <BoxView HeightRequest="1"
                             BackgroundColor="{StaticResource SurfaceAltColor}"
                             Margin="0,4"
                             IsVisible="{Binding IsAzureSelected}" />

                    <Label Text="Azure Subscription Key"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="{StaticResource PrimaryTextColor}"
                           IsVisible="{Binding IsAzureSelected}" />
                    <Entry Text="{Binding TtsAzureKey}"
                           Placeholder="Paste your Azure Speech key here"
                           IsPassword="True"
                           IsVisible="{Binding IsAzureSelected}" />

                    <Label Text="Azure Region"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="{StaticResource PrimaryTextColor}"
                           IsVisible="{Binding IsAzureSelected}" />
                    <Entry Text="{Binding TtsAzureRegion}"
                           Placeholder="e.g. eastus"
                           IsVisible="{Binding IsAzureSelected}" />

                    <!-- ElevenLabs settings -->
                    <BoxView HeightRequest="1"
                             BackgroundColor="{StaticResource SurfaceAltColor}"
                             Margin="0,4"
                             IsVisible="{Binding IsElevenLabsSelected}" />

                    <Label Text="ElevenLabs API Key"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="{StaticResource PrimaryTextColor}"
                           IsVisible="{Binding IsElevenLabsSelected}" />
                    <Entry Text="{Binding TtsElevenLabsKey}"
                           Placeholder="Paste your ElevenLabs API key here"
                           IsPassword="True"
                           IsVisible="{Binding IsElevenLabsSelected}" />

                    <Label Text="Voice selection is available in the chat screen voice picker."
                           FontSize="11"
                           TextColor="{StaticResource SecondaryTextColor}" />

                </VerticalStackLayout>
            </Border>

            <!-- ═══════════════════════════════════════════ -->
            <!-- Section: Health Connect (Android-only)      -->
            <!-- ═══════════════════════════════════════════ -->
            <Label Text="HEALTH"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="{StaticResource SecondaryTextColor}"
                   Margin="20,20,20,6"
                   CharacterSpacing="1.5"
                   IsVisible="{Binding IsHealthConnectAvailable}" />

            <Border Margin="12,0"
                    Padding="16"
                    StrokeThickness="0"
                    BackgroundColor="{StaticResource SurfaceColor}"
                    IsVisible="{Binding IsHealthConnectAvailable}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">

                    <Label Text="Health Connect"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="{StaticResource PrimaryTextColor}" />

                    <Label Text="{Binding HealthStatusText}"
                           FontSize="13"
                           TextColor="{StaticResource SecondaryTextColor}" />

                    <Button Text="Connect Health"
                            Command="{Binding ConnectHealthCommand}"
                            Margin="0,4,0,0" />

                    <Label Text="Grants read access to steps, sleep, heart rate, and distance from Health Connect."
                           FontSize="11"
                           TextColor="{StaticResource SecondaryTextColor}" />

                </VerticalStackLayout>
            </Border>

            <!-- ═══════════════════════════════════════════ -->
            <!-- Section: Coco (Windows only)               -->
            <!-- ═══════════════════════════════════════════ -->
            <Label Text="COCO — CODE INTELLIGENCE"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="{StaticResource SecondaryTextColor}"
                   Margin="20,20,20,6"
                   CharacterSpacing="1.5"
                   IsVisible="{Binding IsCocoSectionVisible}" />

            <Border Margin="12,0"
                    Padding="16"
                    StrokeThickness="0"
                    BackgroundColor="{StaticResource SurfaceColor}"
                    IsVisible="{Binding IsCocoSectionVisible}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Text="Enable Coco"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{StaticResource PrimaryTextColor}"
                               VerticalOptions="Center" />
                        <Switch Grid.Column="1"
                                IsToggled="{Binding CocoEnabled, Mode=TwoWay}"
                                VerticalOptions="Center" />
                    </Grid>

                    <BoxView HeightRequest="1"
                             BackgroundColor="{StaticResource SurfaceAltColor}"
                             Margin="0,4" />

                    <Label Text="Coco API URL"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="{StaticResource PrimaryTextColor}" />
                    <Entry Text="{Binding CocoBaseUrl, Mode=TwoWay}"
                           Placeholder="http://localhost:5292" />

                    <BoxView HeightRequest="1"
                             BackgroundColor="{StaticResource SurfaceAltColor}"
                             Margin="0,4" />

                    <Label Text="Project Path to Index"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="{StaticResource PrimaryTextColor}" />
                    <Entry Text="{Binding CocoProjectPath, Mode=TwoWay}"
                           Placeholder="e.g. C:\source\repos\MyProject" />

                    <BoxView HeightRequest="1"
                             BackgroundColor="{StaticResource SurfaceAltColor}"
                             Margin="0,4" />

                    <Label Text="Status"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="{StaticResource PrimaryTextColor}" />
                    <Label Text="{Binding CocoStatusText}"
                           FontSize="13"
                           TextColor="{StaticResource SecondaryTextColor}" />

                    <Grid ColumnDefinitions="*,*,*"
                          ColumnSpacing="8">
                        <Button Grid.Column="0"
                                Text="Check Status"
                                Command="{Binding RefreshCocoStatusCommand}"
                                IsEnabled="{Binding IsIndexing, Converter={StaticResource InverseBoolConverter}}" />
                        <Button Grid.Column="1"
                                Text="Index Project"
                                Command="{Binding IndexCocoPathCommand}"
                                IsEnabled="{Binding IsIndexing, Converter={StaticResource InverseBoolConverter}}" />
                        <Button Grid.Column="2"
                                Text="Cancel"
                                Command="{Binding CancelIndexCommand}"
                                IsEnabled="{Binding IsIndexing}"
                                BackgroundColor="#C62828" />
                    </Grid>

                    <Label Text="Indexes .cs files in the project path for code-intelligence queries."
                           FontSize="11"
                           TextColor="{StaticResource SecondaryTextColor}" />

                    <BoxView HeightRequest="1"
                             BackgroundColor="{StaticResource SurfaceAltColor}"
                             Margin="0,4" />

                    <!-- Clipboard monitor toggle -->
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Text="Clipboard monitoring"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{StaticResource PrimaryTextColor}"
                               VerticalOptions="Center" />
                        <Switch Grid.Column="1"
                                IsToggled="{Binding CocoClipboardMonitorEnabled, Mode=TwoWay}"
                                VerticalOptions="Center" />
                    </Grid>
                    <Label Text="When enabled, code copied to the clipboard is automatically pre-filled in the chat input for a Coco query."
                           FontSize="11"
                           TextColor="{StaticResource SecondaryTextColor}" />

                    <BoxView HeightRequest="1"
                             BackgroundColor="{StaticResource SurfaceAltColor}"
                             Margin="0,4" />

                    <!-- Global hotkey -->
                    <Label Text="Global hotkey"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="{StaticResource PrimaryTextColor}" />
                    <Entry Text="{Binding CocoHotkey, Mode=TwoWay}"
                           Placeholder="e.g. Ctrl+Shift+C" />
                    <Label Text="Pressing this key combination brings LAA to the foreground and activates Ask Coco mode. Supported modifiers: Ctrl, Shift, Alt."
                           FontSize="11"
                           TextColor="{StaticResource SecondaryTextColor}" />

                </VerticalStackLayout>
            </Border>

            <!-- ═══════════════════════════════════════════ -->
            <!-- Section: Google Calendar                    -->
            <!-- ═══════════════════════════════════════════ -->
            <Label Text="GOOGLE CALENDAR"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="{StaticResource SecondaryTextColor}"
                   Margin="20,20,20,6"
                   CharacterSpacing="1.5" />

            <Border Margin="12,0"
                    Padding="16"
                    StrokeThickness="0"
                    BackgroundColor="{StaticResource SurfaceColor}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">

                    <Label Text="Google OAuth Client ID"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="{StaticResource PrimaryTextColor}" />
                    <Entry Text="{Binding GoogleCalendarClientId, Mode=TwoWay}"
                           Placeholder="Paste your OAuth Client ID here" />
                    <Label Text="Create an OAuth 2.0 Client ID (Desktop app) in Google Cloud Console."
                           FontSize="11"
                           TextColor="{StaticResource SecondaryTextColor}" />

                    <BoxView HeightRequest="1"
                             BackgroundColor="{StaticResource SurfaceAltColor}"
                             Margin="0,4" />

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Text="Status"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{StaticResource PrimaryTextColor}"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="{Binding GoogleCalendarStatusText}"
                               FontSize="13"
                               TextColor="{StaticResource SecondaryTextColor}"
                               VerticalOptions="Center" />
                    </Grid>

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="8">
                        <Button Grid.Column="0"
                                Text="Connect"
                                Command="{Binding ConnectCalendarCommand}" />
                        <Button Grid.Column="1"
                                Text="Disconnect"
                                Command="{Binding DisconnectCalendarCommand}"
                                BackgroundColor="#C62828" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- ═══════════════════════════════════════════ -->
            <!-- Save                                        -->
            <!-- ═══════════════════════════════════════════ -->
            <Button Text="Save"
                    Command="{Binding SaveCommand}"
                    Margin="12,20,12,4"
                    HeightRequest="48" />

            <Label Text="Applies Ollama connection and model settings."
                   FontSize="11"
                   TextColor="{StaticResource SecondaryTextColor}"
                   HorizontalOptions="Center"
                   Margin="0,4,0,24" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:LocalAIAssistant.ViewModels"
             xmlns:dto="clr-namespace:LocalAIAssistant.Core.ConversationHistory;assembly=LocalAIAssistant.Core"
             x:Class="LocalAIAssistant.Views.ConversationsPage"
             x:DataType="viewModels:ConversationsViewModel"
             Title="Conversations"
             BackgroundColor="{StaticResource SplashBackgroundColor}">

    <Grid RowDefinitions="Auto,*">

        <!-- Toolbar -->
        <Grid Grid.Row="0"
              Padding="12,8"
              ColumnDefinitions="*,Auto"
              BackgroundColor="{StaticResource SurfaceColor}">

            <Label Grid.Column="0"
                   Text="Past Conversations"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="{StaticResource PrimaryTextColor}"
                   VerticalOptions="Center"/>

            <Button Grid.Column="1"
                    Text="New Chat"
                    Command="{Binding NewConversationCommand}"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    Padding="12,6"
                    CornerRadius="6"/>

        </Grid>

        <!-- Content -->
        <Grid Grid.Row="1">

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>

            <CollectionView ItemsSource="{Binding Conversations}"
                            IsVisible="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}">

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="dto:ConversationSummaryDto">
                        <SwipeView>

                            <SwipeView.RightItems>
                                <SwipeItems>
                                    <SwipeItem Text="Delete"
                                               BackgroundColor="Red"
                                               Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:ConversationsViewModel}}, Path=DeleteConversationCommand}"
                                               CommandParameter="{Binding}"/>
                                </SwipeItems>
                            </SwipeView.RightItems>

                            <Border Padding="14,12"
                                    Margin="8,4"
                                    BackgroundColor="{StaticResource SurfaceColor}"
                                    Stroke="Transparent"
                                    StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:ConversationsViewModel}}, Path=SelectConversationCommand}"
                                                          CommandParameter="{Binding}"/>
                                </Border.GestureRecognizers>

                                <Grid ColumnDefinitions="*,Auto">

                                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                                        <Label Text="{Binding Name, TargetNullValue='Unnamed conversation'}"
                                               FontSize="15"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource PrimaryTextColor}"
                                               LineBreakMode="TailTruncation"/>
                                        <Label FontSize="12"
                                               TextColor="{StaticResource SecondaryTextColor}">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="{Binding MessageCount}"/>
                                                    <Span Text=" messages"/>
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>
                                    </VerticalStackLayout>

                                    <Label Grid.Column="1"
                                           Text="{Binding LastActiveUtc, StringFormat='{0:MMM d}'}"
                                           FontSize="12"
                                           TextColor="{StaticResource SecondaryTextColor}"
                                           VerticalOptions="Center"/>

                                </Grid>
                            </Border>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center"
                                         VerticalOptions="Center"
                                         Spacing="8"
                                         Padding="32">
                        <Label Text="No past conversations"
                               FontSize="16"
                               HorizontalOptions="Center"
                               TextColor="{StaticResource SecondaryTextColor}"/>
                        <Label Text="Start a new chat to get going."
                               FontSize="13"
                               HorizontalOptions="Center"
                               TextColor="{StaticResource SecondaryTextColor}"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

            </CollectionView>

        </Grid>

    </Grid>

</ContentPage>

<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LocalAIAssistant.Views.DebugStartupPage"
             BackgroundColor="Black"
             Title="Startup Diagnostics">
    <ScrollView>
        <StackLayout Padding="20" Spacing="12">
            <Label Text="Startup Diagnostics"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="White" />
            <ActivityIndicator x:Name="Spinner"
                               IsRunning="True"
                               Color="White" />
            <Label x:Name="StatusLabel"
                   Text="Starting..."
                   FontSize="14"
                   TextColor="Yellow" />
            <Label x:Name="LogLabel"
                   Text=""
                   LineBreakMode="WordWrap"
                   FontSize="12"
                   TextColor="White" />
            <Button x:Name="GoToAppButton"
                    Text="Go to App"
                    IsVisible="False"
                    Clicked="OnGoToAppClicked" />
        </StackLayout>
    </ScrollView>
</ContentPage>

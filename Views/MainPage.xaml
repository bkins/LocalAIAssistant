            <!-- Messages Background Layer -->
            <!-- Messages Background Layer -->
            <Grid Grid.Row="1"
                  Margin="12">

                <!-- Dark overlay to keep contrast -->
                <BoxView
                    Color="Black" />

                <!-- Background image -->
                <Image x:Name="BackgroundGlyph"
                       Source="appicon_background.png"
                       Aspect="Center"
                       Scale="0.5"
                       Opacity="0.5" />


                <!-- Messages -->
                <CollectionView x:Name="MessagesView"
                                ItemsSource="{Binding Messages}"
                                BackgroundColor="Transparent"
                                VerticalOptions="FillAndExpand">

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame
                                Padding="12"
                                Margin="0,6"
                                BorderColor="#000000"
                                HasShadow="False"
                                CornerRadius="12"
                                MaximumWidthRequest="320"
                                HorizontalOptions="Start"
                                BackgroundColor="{StaticResource SurfaceColor}">

                                <Frame.Triggers>

                                    <!-- USER MESSAGE -->
                                    <DataTrigger TargetType="Frame"
                                                 Binding="{Binding Sender}"
                                                 Value="user">
                                        <Setter Property="BackgroundColor" Value="#4CAF50" />
                                        <Setter Property="HorizontalOptions" Value="End" />
                                    </DataTrigger>

                                    <!-- ASSISTANT MESSAGE -->
                                    <DataTrigger TargetType="Frame"
                                                 Binding="{Binding Sender}"
                                                 Value="assistant">
                                        <Setter Property="BackgroundColor" Value="#7C5CE6" />
                                        <Setter Property="HorizontalOptions" Value="Start" />
                                    </DataTrigger>

                                    <!-- SYSTEM MESSAGE -->
                                    <DataTrigger TargetType="Frame"
                                                 Binding="{Binding Sender}"
                                                 Value="system">
                                        <Setter Property="BackgroundColor" Value="Transparent" />
                                        <Setter Property="HorizontalOptions" Value="Center" />
                                    </DataTrigger>

                                </Frame.Triggers>

                                <Label Text="{Binding Content}"
                                       LineBreakMode="WordWrap"
                                       FontSize="14">

                                    <Label.Triggers>

                                        <!-- USER TEXT -->
                                        <DataTrigger TargetType="Label"
                                                     Binding="{Binding Sender}"
                                                     Value="user">
                                            <Setter Property="TextColor" Value="White" />
                                            <Setter Property="FontFamily" Value="Default" />
                                        </DataTrigger>

                                        <!-- ASSISTANT TEXT -->
                                        <DataTrigger TargetType="Label"
                                                     Binding="{Binding Sender}"
                                                     Value="assistant">
                                            <Setter Property="TextColor" Value="#0F172A" />
                                            <Setter Property="FontFamily" Value="JetBrainsMono" />
                                        </DataTrigger>

                                        <!-- SYSTEM TEXT -->
                                        <DataTrigger TargetType="Label"
                                                     Binding="{Binding Sender}"
                                                     Value="system">
                                            <Setter Property="TextColor" Value="Red" />
                                            <Setter Property="FontAttributes" Value="Italic" />
                                            <Setter Property="HorizontalTextAlignment" Value="Center" />
                                        </DataTrigger>

                                    </Label.Triggers>
                                </Label>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                </CollectionView>
            </Grid>


            <!-- Input Bar -->
            <Grid Row="2"
                  Padding="12"
                  ColumnDefinitions="*,Auto"
                  BackgroundColor="{StaticResource SurfaceColor}">

                <Entry Grid.Column="0"
                       Text="{Binding PromptText}"
                       Placeholder="Type a message…"
                       FontSize="16"
                       HeightRequest="44"
                       VerticalOptions="Center"
                       BackgroundColor="{StaticResource InputBackgroundColor}"
                       TextColor="White"

                       Margin="0,0,8,0" />
                <!-- Command="{Binding SendForStreamingCommand}" -->
                <Button Grid.Column="1"
                        Text="Send"
                        Command="{Binding SendCommand}"
                        HeightRequest="44"
                        Padding="16,0" />
            </Grid>
        </Grid>

<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:LocalAIAssistant.Views.Controls"
             x:Class="LocalAIAssistant.Views.MainPage"
             BackgroundColor="{StaticResource SplashBackgroundColor}"
             Title="Local AI Assistant">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="🧭"
                     Command="{Binding OpenKnowledgeCommand}" />
    </ContentPage.ToolbarItems>

    <Grid x:Name="Root"
          Opacity="0"
          BackgroundColor="Black">

        <Grid RowDefinitions="Auto,*,Auto">

            <!-- Streaming toggle header — only visible when ShowStreamingOption is true -->
            <Grid Padding="16"
                  BackgroundColor="{StaticResource SurfaceAltColor}"
                  Row="0"
                  IsVisible="{Binding ShowStreamingOption}">

                <HorizontalStackLayout Spacing="40"
                                       VerticalOptions="Center">

                    <Label Text="Streaming"
                           TextColor="{StaticResource SecondaryTextColor}"
                           VerticalTextAlignment="Center" />

                    <Switch IsToggled="{Binding UseStreaming}"
                            VerticalOptions="Center"
                            HorizontalOptions="End" />

                </HorizontalStackLayout>
            </Grid>

            <!-- Message list -->
            <Grid Grid.Row="1"
                  Margin="12">

                <!-- Dark overlay to keep contrast -->
                <BoxView Color="Black" />

                <!-- Background glyph — animated from code-behind -->
                <Image x:Name="BackgroundGlyph"
                       Source="appicon_background.png"
                       Aspect="Center"
                       Scale="0.5"
                       Opacity="0.5" />
                <!-- ItemsUpdatingScrollMode="KeepLastItemInView" -->
                <!-- Scrolled="OnCollectionViewScrolled" -->
                <CollectionView x:Name="MessagesView"
                                
                                ItemsSource="{Binding Messages}"
                                ItemSizingStrategy="MeasureAllItems"
                                BackgroundColor="Transparent"
                                VerticalOptions="Fill">
                    
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <!--
                                Border replaces the deprecated Frame.
                                  • StrokeShape supplies the rounded corners.
                                  • StrokeThickness="0" hides the border line.
                                  • Triggers adjust BackgroundColor / HorizontalOptions per sender.
                            -->
                            <Border Padding="12"
                                    Margin="0,6"
                                    Stroke="#000000"
                                    StrokeThickness="0"
                                    MaximumWidthRequest="480"
                                    HorizontalOptions="Start"
                                    VerticalOptions="Start"
                                    BackgroundColor="{StaticResource SurfaceColor}">
                                
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnMessageTapped" />
                                </Border.GestureRecognizers>
                                
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>

                                <Border.Triggers>

                                    <DataTrigger TargetType="Border"
                                                 Binding="{Binding Sender}"
                                                 Value="user">
                                        <Setter Property="BackgroundColor"  Value="#4CAF50" />
                                        <Setter Property="HorizontalOptions" Value="End" />
                                    </DataTrigger>

                                    <DataTrigger TargetType="Border"
                                                 Binding="{Binding Sender}"
                                                 Value="assistant">
                                        <Setter Property="BackgroundColor"  Value="#7C5CE6" />
                                        <Setter Property="HorizontalOptions" Value="Start" />
                                    </DataTrigger>

                                    <DataTrigger x:Name="SystemDataTrigger" TargetType="Border"
                                                 Binding="{Binding Sender}"
                                                 Value="system">
                                        <Setter Property="BackgroundColor"  Value="Transparent" />
                                        <Setter Property="HorizontalOptions" Value="Center" />
                                    </DataTrigger>

                                </Border.Triggers>

                                <Grid ColumnDefinitions="*" VerticalOptions="Start">
                                    <controls:NativeMarkdownView 
                                        Grid.Column="0"
                                        Markdown="{Binding Content}"
                                        HorizontalOptions="Fill"
                                        VerticalOptions="Start" />
                                    <Label Text="⚡"
                                           FontSize="14"
                                           HorizontalOptions="End"
                                           VerticalOptions="Start"
                                           Margin="0,-8,-4,0" 
                                           IsVisible="{Binding WasFastPath}"
                                           InputTransparent="True">
                                        <Label.Shadow>
                                            <Shadow Brush="Black" 
                                                    Offset="1,1" 
                                                    Radius="2" 
                                                    Opacity="0.5" />
                                        </Label.Shadow>
                                    </Label>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>

            <!-- Input bar -->
            <Grid Grid.Row="2"
                  Padding="12"
                  ColumnDefinitions="*,Auto"
                  BackgroundColor="{StaticResource SurfaceColor}">

                <Editor Grid.Column="0"
                        Text="{Binding PromptText}"
                        Placeholder="Type a message…"
                        AutoSize="TextChanges"
                        Keyboard="Text"
                        FontSize="16"
                        MinimumHeightRequest="44"
                        VerticalOptions="Center"
                        BackgroundColor="{StaticResource InputBackgroundColor}"
                        TextColor="White"
                        Margin="0,0,8,0"
                        IsEnabled="{Binding IsTyping, Converter={StaticResource InverseBoolConverter}}"
                        Completed="OnEntryCompleted" />

                <Button Grid.Column="1"
                        Text="Send"
                        Command="{Binding SendAsyncCommand}"
                        IsEnabled="{Binding IsTyping, Converter={StaticResource InverseBoolConverter}}"
                        HeightRequest="44"
                        Padding="16,0"
                        BackgroundColor="#4CAF50" />

            </Grid>
        </Grid>
    </Grid>
</ContentPage>

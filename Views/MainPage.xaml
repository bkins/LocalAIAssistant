<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:LocalAIAssistant.Views.Controls"
             x:Class="LocalAIAssistant.Views.MainPage"
             BackgroundColor="{StaticResource SplashBackgroundColor}"
             Title="Local AI Assistant">

    <Grid x:Name="Root"
          Opacity="0"
          BackgroundColor="Black">

        <Grid RowDefinitions="Auto,*,Auto">

            <!-- Toolbars row: TTS (always shown when available) + streaming (debug only) -->
            <VerticalStackLayout Grid.Row="0" Spacing="0">

                <!-- TTS toolbar — hidden when TTS hardware/OS feature is unavailable -->
                <Grid Padding="12,8"
                      BackgroundColor="{StaticResource SurfaceAltColor}"
                      IsVisible="{Binding TtsIsAvailable}">

                    <HorizontalStackLayout Spacing="12"
                                           VerticalOptions="Center">

                        <Label Text="Read aloud"
                               FontSize="13"
                               TextColor="{StaticResource SecondaryTextColor}"
                               VerticalTextAlignment="Center" />

                        <Switch IsToggled="{Binding TtsIsEnabled, Mode=TwoWay}"
                                VerticalOptions="Center" />

                        <Picker ItemsSource="{Binding TtsVoices}"
                                SelectedItem="{Binding TtsSelectedVoice, Mode=TwoWay}"
                                Title="Voice"
                                IsVisible="{Binding TtsIsEnabled}"
                                MinimumWidthRequest="160"
                                VerticalOptions="Center"
                                FontSize="13"
                                TextColor="{StaticResource PrimaryTextColor}" />

                    </HorizontalStackLayout>
                </Grid>

                <!-- Streaming toggle — debug feature, hidden by default -->
                <Grid Padding="16"
                      BackgroundColor="{StaticResource SurfaceAltColor}"
                      IsVisible="{Binding ShowStreamingOption}">

                    <HorizontalStackLayout Spacing="40"
                                           VerticalOptions="Center">

                        <Label Text="Streaming"
                               TextColor="{StaticResource SecondaryTextColor}"
                               VerticalTextAlignment="Center" />

                        <Switch IsToggled="{Binding UseStreaming}"
                                VerticalOptions="Center"
                                HorizontalOptions="End" />

                    </HorizontalStackLayout>
                </Grid>

            </VerticalStackLayout>

            <!-- Message list — children placed directly in the * row so the
                 CollectionView receives an EXACTLY-bounded height from the row.
                 A single-cell wrapper Grid would pass an unconstrained measure to
                 CollectionView, letting it report its full content height and
                 overflow the row's touch area on Android. -->
            <BoxView Grid.Row="1"
                     Color="Black"
                     Margin="12" />

            <!-- Background glyph — animated from code-behind -->
            <Image Grid.Row="1"
                   x:Name="BackgroundGlyph"
                   Source="appicon_background.png"
                   Aspect="Center"
                   Scale="0.5"
                   Opacity="0.5"
                   Margin="12" />

            <!-- ItemsUpdatingScrollMode="KeepLastItemInView" -->
            <!-- Scrolled="OnCollectionViewScrolled" -->
            <CollectionView Grid.Row="1"
                            x:Name="MessagesView"
                            Margin="12"
                            ItemsSource="{Binding Messages}"
                            ItemSizingStrategy="MeasureAllItems"
                            BackgroundColor="Transparent"
                            VerticalOptions="Fill">

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <!--
                                Border replaces the deprecated Frame.
                                  • StrokeShape supplies the rounded corners.
                                  • StrokeThickness="0" hides the border line.
                                  • Sender triggers set BackgroundColor / HorizontalOptions per sender.
                                  • IsInsight trigger (last) overrides color for insight turns.
                            -->
                            <Border Padding="12"
                                    Margin="0,6"
                                    Stroke="#000000"
                                    StrokeThickness="0"
                                    MaximumWidthRequest="480"
                                    HorizontalOptions="Start"
                                    VerticalOptions="Start"
                                    BackgroundColor="{StaticResource SurfaceColor}">

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnMessageTapped" />
                                </Border.GestureRecognizers>

                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>

                                <Border.Triggers>

                                    <DataTrigger TargetType="Border"
                                                 Binding="{Binding Sender}"
                                                 Value="user">
                                        <Setter Property="BackgroundColor"   Value="#4CAF50" />
                                        <Setter Property="HorizontalOptions" Value="End" />
                                    </DataTrigger>

                                    <DataTrigger TargetType="Border"
                                                 Binding="{Binding Sender}"
                                                 Value="assistant">
                                        <Setter Property="BackgroundColor"   Value="#7C5CE6" />
                                        <Setter Property="HorizontalOptions" Value="Start" />
                                    </DataTrigger>

                                    <DataTrigger x:Name="SystemDataTrigger" TargetType="Border"
                                                 Binding="{Binding Sender}"
                                                 Value="system">
                                        <Setter Property="BackgroundColor"   Value="Transparent" />
                                        <Setter Property="HorizontalOptions" Value="Center" />
                                    </DataTrigger>

                                    <!-- Insight override: amber card, left-aligned -->
                                    <DataTrigger TargetType="Border"
                                                 Binding="{Binding IsInsight}"
                                                 Value="True">
                                        <Setter Property="BackgroundColor"   Value="#1F1600" />
                                        <Setter Property="HorizontalOptions" Value="Start" />
                                        <Setter Property="Stroke"            Value="#C89618" />
                                        <Setter Property="StrokeThickness"   Value="1" />
                                    </DataTrigger>

                                </Border.Triggers>

                                <VerticalStackLayout Spacing="4">

                                    <!-- Insight header label — only visible for insight messages -->
                                    <Label Text="Insight"
                                           FontSize="11"
                                           FontAttributes="Bold,Italic"
                                           TextColor="#C89618"
                                           IsVisible="{Binding IsInsight}" />

                                    <Grid ColumnDefinitions="*" VerticalOptions="Start">
                                        <controls:NativeMarkdownView
                                            Grid.Column="0"
                                            Markdown="{Binding DisplayContent}"
                                            HorizontalOptions="Fill"
                                            VerticalOptions="Start" />
                                        <Label Text="⚡"
                                               FontSize="14"
                                               HorizontalOptions="End"
                                               VerticalOptions="Start"
                                               Margin="0,-8,-4,0"
                                               IsVisible="{Binding WasFastPath}"
                                               InputTransparent="True">
                                            <Label.Shadow>
                                                <Shadow Brush="Black"
                                                        Offset="1,1"
                                                        Radius="2"
                                                        Opacity="0.5" />
                                            </Label.Shadow>
                                        </Label>
                                        <Label Text="💡"
                                               FontSize="14"
                                               HorizontalOptions="End"
                                               VerticalOptions="Start"
                                               Margin="0,-8,-4,0"
                                               IsVisible="{Binding IsInsight}"
                                               InputTransparent="True">
                                            <Label.Shadow>
                                                <Shadow Brush="Black"
                                                        Offset="1,1"
                                                        Radius="2"
                                                        Opacity="0.5" />
                                            </Label.Shadow>
                                        </Label>
                                    </Grid>

                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Input bar -->
            <Grid Grid.Row="2"
                  Padding="12"
                  ColumnDefinitions="*,Auto,Auto"
                  BackgroundColor="{StaticResource SurfaceColor}">

                <Editor Grid.Column="0"
                        Text="{Binding PromptText}"
                        Placeholder="Type a message…"
                        AutoSize="TextChanges"
                        Keyboard="Text"
                        FontSize="16"
                        MinimumHeightRequest="44"
                        VerticalOptions="Center"
                        BackgroundColor="{StaticResource InputBackgroundColor}"
                        TextColor="White"
                        Margin="0,0,8,0"
                        IsEnabled="{Binding IsTyping, Converter={StaticResource InverseBoolConverter}}"
                        TextChanged="OnEditorTextChanged" />

                <Button Grid.Column="1"
                        Text="Send"
                        Command="{Binding SendCommand}"
                        IsEnabled="{Binding IsTyping, Converter={StaticResource InverseBoolConverter}}"
                        HeightRequest="44"
                        Padding="16,0"
                        BackgroundColor="#4CAF50" />

                <Button Grid.Column="2"
                        Text="Clear"
                        Clicked="OnClearButtonClicked"
                        IsEnabled="{Binding IsTyping, Converter={StaticResource InverseBoolConverter}}"
                        HeightRequest="44"
                        Padding="12,0"
                        Margin="8,0,0,0"
                        BackgroundColor="#C62828" />

            </Grid>
        </Grid>
    </Grid>
</ContentPage>

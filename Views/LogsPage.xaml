<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:LocalAIAssistant.ViewModels"
             xmlns:converters1="clr-namespace:LocalAIAssistant.Converters"
             x:Class="LocalAIAssistant.Views.LogsPage"
             Title="Application Logs"
             x:Name="Page">

    <ContentPage.Resources>
        <ResourceDictionary Source="/Resources/Styles/Colors.xaml"/>
        <converters1:LogLevelToColorConverter x:Key="LogLevelToColorConverter"/>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, *" Padding="10">
        <!-- Top Section: Error, Loading, Buttons -->
        <VerticalStackLayout Spacing="10" Grid.Row="0">
            <!-- Error Message -->
            <VerticalStackLayout IsVisible="{Binding HasError}">
                <Border BackgroundColor="#FFEBEE"
                        Stroke="#FFCDD2"
                        StrokeThickness="1"
                        Padding="10">
                    <Label Text="{Binding ErrorMessage}"
                           TextColor="#B71C1C"/>
                </Border>
            </VerticalStackLayout>

            <!-- Loading Indicator -->
            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               HorizontalOptions="Center"/>

            <!-- Action Buttons -->
            <HorizontalStackLayout Spacing="10" 
                                   HorizontalOptions="Center">
                <Button Text="Refresh"
                        Command="{Binding RefreshLogsCommand}"
                        BackgroundColor="LightBlue"/>
                <Button Text="Clear Logs"
                        Command="{Binding ClearLogsCommand}"
                        BackgroundColor="Orange"/>
                <Button Text="Test Logging"
                        Command="{Binding TestLoggingCommand}"
                        BackgroundColor="LightGreen"/>
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <!-- Scrollable Logs -->
        <CollectionView x:Name="LogCollection"
                        Grid.Row="1"
                        ItemsSource="{Binding LogEntries}"
                        SelectionMode="Single"
                        SelectedItem="{Binding SelectedLogEntry, Mode=TwoWay}">
            
            <!-- SelectedItem="{Binding SelectedLogEntry}" -->
                        <!-- SelectionChanged="OnSelectionChanged"> -->
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 5"
                            Margin="5"
                            Padding="10">
                        <Grid RowDefinitions="Auto, Auto" 
                              ColumnDefinitions="*, Auto">
                            <!-- Timestamp and Level -->
                            <HorizontalStackLayout Grid.Row="0" 
                                                   Grid.Column="0" 
                                                   Spacing="10">
                                <Label Text="{Binding FormattedTimestamp}"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"/>
                                <Border BackgroundColor="{Binding Level, Converter={StaticResource LogLevelToColorConverter}}"
                                        StrokeThickness="0"
                                        Padding="4,2">
                                    <Label Text="{Binding Level}"
                                           FontSize="10"
                                           TextColor="White"
                                           FontAttributes="Bold"/>
                                </Border>
                            </HorizontalStackLayout>

                            <!-- Message -->
                            <Label Grid.Row="1" Grid.Column="0"
                                   Text="{Binding Message}"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray100}}"
                                   LineBreakMode="WordWrap"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" 
                                     VerticalOptions="Center">
                    <Label Text="No log entries found"
                           HorizontalOptions="Center"
                           FontSize="16"
                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"/>
                    <Label Text="Try adding some test logs or check if logging is working"
                           HorizontalOptions="Center"
                           FontSize="12"
                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray500}}"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>
    </Grid>
</ContentPage>


<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LocalAIAssistant.Knowledge.Journals.Views.JournalDetailPage"
             xmlns:converters="clr-namespace:LocalAIAssistant.Knowledge"
             Title="Journal"
             >
    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:TagsToTextConverter x:Key="TagsToText" />
        </ResourceDictionary>
    </ContentPage.Resources>

       <VerticalStackLayout Padding="16" Spacing="10">

              <!-- Header -->
              <Label
                     Text="{Binding CreatedAt, StringFormat='{0:MMMM d, yyyy · h:mm tt}'}"
                     FontSize="12"
                     TextColor="{AppThemeBinding Light=#666, Dark=#AAA}" />

              <Label
                     Text="Edited"
                     FontSize="12"
                     TextColor="#CC8844"
                     IsVisible="{Binding IsEdited}" />

              <!-- Body -->
              <Label
                     Text="{Binding Text}"
                     FontSize="16"
                     LineBreakMode="WordWrap" />

              <!-- Metadata -->
              <VerticalStackLayout Spacing="4">

                     <Label
                            Text="{Binding Tags, Converter={StaticResource TagsToText}}"
                            FontSize="12"
                            TextColor="{AppThemeBinding Light=#666, Dark=#AAA}"
                            IsVisible="{Binding Tags.Count}" />

                     <Label
                            Text="{Binding Mood}"
                            FontSize="12"
                            TextColor="{AppThemeBinding Light=#666, Dark=#AAA}"
                            IsVisible="{Binding Mood}" />
                     <Label
                            Text="{Binding MoodScore}"
                            FontSize="12"
                            TextColor="{AppThemeBinding Light=#666, Dark=#AAA}"
                            IsVisible="{Binding MoodScore}" />
              </VerticalStackLayout>

              <ActivityIndicator
                     IsRunning="{Binding IsLoading}"
                     IsVisible="{Binding IsLoading}" />

       </VerticalStackLayout>

       

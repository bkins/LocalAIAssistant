<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LocalAIAssistant.Knowledge.Journals.Views.JournalDetailPage"
             xmlns:converters1="clr-namespace:LocalAIAssistant.Converters"
             Title="Journal">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters1:TagsToTextConverter         x:Key="TagsToText" />
            <converters1:IntGreaterThanZeroConverter x:Key="IntGtZero" />
            <converters1:NullToBoolConverter         x:Key="NullToBool" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Header / Metadata / Actions -->
        <VerticalStackLayout Grid.Row="0" Padding="16" Spacing="8">

            <Label Text="{Binding CreatedAt, StringFormat='{0:MMMM d, yyyy · h:mm tt}'}"
                   FontSize="12"
                   TextColor="{AppThemeBinding Light=#666, Dark=#AAA}" />

            <Button Text="View revision history"
                    FontSize="12"
                    Padding="6,4"
                    HorizontalOptions="Start"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light=#666, Dark=#AAA}"
                    Command="{Binding ViewRevisionHistoryCommand}" />

            <Label Text="Edited"
                   FontSize="12"
                   TextColor="#CC8844"
                   IsVisible="{Binding IsEdited}" />

            <!-- Metadata moved up -->
            <Label Text="{Binding Tags, Converter={StaticResource TagsToText}}"
                   FontSize="12"
                   TextColor="{AppThemeBinding Light=#666, Dark=#AAA}"
                   IsVisible="{Binding Tags.Count, Converter={StaticResource IntGtZero}}" />

            <Label Text="{Binding Mood}"
                   FontSize="12"
                   TextColor="{AppThemeBinding Light=#666, Dark=#AAA}"
                   IsVisible="{Binding Mood, Converter={StaticResource NullToBool}}" />

            <Label Text="{Binding MoodScore}"
                   FontSize="12"
                   TextColor="{AppThemeBinding Light=#666, Dark=#AAA}"
                   IsVisible="{Binding MoodScore, Converter={StaticResource NullToBool}}" />

            <Button Text="Edit entry"
                    FontSize="12"
                    BackgroundColor="Transparent"
                    Command="{Binding EditEntryCommand}" />

        </VerticalStackLayout>

        <!-- Divider -->
        <BoxView Grid.Row="1"
                 HeightRequest="1"
                 Margin="16,0"
                 Color="{AppThemeBinding Light=#DDD, Dark=#333}" />

        <!-- Scrollable Body Only -->
        <ScrollView Grid.Row="2">
            <VerticalStackLayout Padding="16">
                <Label Text="{Binding Text}"
                       FontSize="16"
                       LineBreakMode="WordWrap" />
            </VerticalStackLayout>
        </ScrollView>

        <!-- Loading overlay -->
        <ActivityIndicator
            IsRunning="{Binding IsLoading}"
            IsVisible="{Binding IsLoading}"
            VerticalOptions="Center"
            HorizontalOptions="Center"
            Grid.RowSpan="3" />

    </Grid>
</ContentPage>

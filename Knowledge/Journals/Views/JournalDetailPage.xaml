<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LocalAIAssistant.Knowledge.Journals.Views.JournalDetailPage"
             xmlns:controls="clr-namespace:LocalAIAssistant.Views.Controls"
             xmlns:converters1="clr-namespace:LocalAIAssistant.Converters"
             xmlns:vm="clr-namespace:LocalAIAssistant.Knowledge.Journals.ViewModels"
             Title="Journal">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters1:TagsToTextConverter         x:Key="TagsToText" />
            <converters1:IntGreaterThanZeroConverter x:Key="IntGtZero" />
            <converters1:NullToBoolConverter         x:Key="NullToBool" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Header / Metadata / Actions -->
        <VerticalStackLayout Grid.Row="0" Padding="16" Spacing="8">
            <Border Padding="10,6"
                    BackgroundColor="#553300"
                    IsVisible="{Binding HasError}">
                <Label Text="Offline — Data will not be displayed or saved until connection is restored"
                       FontSize="12"
                       TextColor="#FFCC88"
                       HorizontalOptions="Center" />
            </Border>
            
            <Label Text="{Binding CreatedAt, StringFormat='{0:MMMM d, yyyy · h:mm tt}'}"
                   FontSize="12"
                   TextColor="{AppThemeBinding Light=#666, Dark=#AAA}" />

            <Button Text="View revision history"
                    FontSize="12"
                    Padding="6,4"
                    HorizontalOptions="Start"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light=#666, Dark=#AAA}"
                    Command="{Binding ViewRevisionHistoryCommand}" />

            <Label Text="Edited"
                   FontSize="12"
                   TextColor="#CC8844"
                   IsVisible="{Binding IsEdited}" />

            <!-- Metadata moved up -->
            <Label Text="{Binding Tags, Converter={StaticResource TagsToText}}"
                   FontSize="12"
                   TextColor="{AppThemeBinding Light=#666, Dark=#AAA}"
                   IsVisible="{Binding Tags.Count, Converter={StaticResource IntGtZero}}" />

            <Label Text="{Binding Mood}"
                   FontSize="12"
                   TextColor="{AppThemeBinding Light=#666, Dark=#AAA}"
                   IsVisible="{Binding Mood, Converter={StaticResource NullToBool}}" />

            <Label Text="{Binding MoodScore}"
                   FontSize="12"
                   TextColor="{AppThemeBinding Light=#666, Dark=#AAA}"
                   IsVisible="{Binding MoodScore, Converter={StaticResource NullToBool}}" />

            <Button Text="Edit entry"
                    FontSize="12"
                    BackgroundColor="Transparent"
                    Command="{Binding EditEntryCommand}" />

            <!-- Attachments (read-only chips, tap to open) -->
            <CollectionView ItemsSource="{Binding Attachments}"
                            IsVisible="{Binding HasAttachments}"
                            HeightRequest="90">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="6" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:AttachmentViewModel">
                        <Border Stroke="{AppThemeBinding Light=#CCC, Dark=#444}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 6"
                                Padding="4"
                                WidthRequest="80">
                            <Grid RowDefinitions="60,Auto" RowSpacing="2">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding OpenCommand}" />
                                </Grid.GestureRecognizers>

                                <Image Grid.Row="0"
                                       Source="{Binding ThumbnailUrl}"
                                       Aspect="AspectFill"
                                       IsVisible="{Binding IsImage}"
                                       HeightRequest="60"
                                       WidthRequest="72" />

                                <Label Grid.Row="0"
                                       Text="📎"
                                       FontSize="30"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       IsVisible="{Binding IsImage, Converter={StaticResource InverseBoolConverter}}" />

                                <Label Grid.Row="1"
                                       Text="{Binding FileName}"
                                       FontSize="10"
                                       LineBreakMode="TailTruncation"
                                       HorizontalOptions="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <HorizontalStackLayout Spacing="8">
                <Switch IsToggled="{Binding ShowAsMarkdown}" />
                <Label Text="Show as Markdown"
                       FontSize="13"
                       VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light=#555, Dark=#BBB}" />
            </HorizontalStackLayout>
            
        </VerticalStackLayout>

        <!-- Divider -->
        <BoxView Grid.Row="1"
                 HeightRequest="1"
                 Margin="16,0"
                 Color="{AppThemeBinding Light=#DDD, Dark=#333}" />

        <!-- Scrollable Body Only -->
        <ScrollView Grid.Row="2">
            <VerticalStackLayout Padding="16">
                <Label Text="{Binding Text}"
                       FontSize="16"
                       LineBreakMode="WordWrap"
                       IsVisible="{Binding ShowAsMarkdown, Converter={StaticResource InverseBoolConverter}}" />
                <controls:NativeMarkdownView Markdown="{Binding Text}"
                                             IsVisible="{Binding ShowAsMarkdown}"
                                             TextColor="{AppThemeBinding Light=Black, Dark=White}" />
            </VerticalStackLayout>
        </ScrollView>

        <!-- Loading overlay -->
        <ActivityIndicator
            IsRunning="{Binding IsLoading}"
            IsVisible="{Binding IsLoading}"
            VerticalOptions="Center"
            HorizontalOptions="Center"
            Grid.RowSpan="3" />

    </Grid>
</ContentPage>

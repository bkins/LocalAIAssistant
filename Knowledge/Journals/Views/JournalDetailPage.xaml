<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LocalAIAssistant.Knowledge.Journals.Views.JournalDetailPage"
             xmlns:converters="clr-namespace:LocalAIAssistant.Knowledge"
             Title="Journal"
             >
    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:TagsToTextConverter x:Key="TagsToText" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <VerticalStackLayout Padding="16" Spacing="8">

        <!-- CreatedAt -->
        <Label Text="{Binding CreatedAt}"
               FontSize="12"
               Opacity="0.7" />

        <!-- Tags -->
        <Label Text="{Binding Tags, Converter={StaticResource TagsToText}}"
               FontSize="12"
               Opacity="0.8" />

        <!-- Mood -->
        <Label Text="{Binding Mood}"
               FontSize="14"/>
               <!-- IsVisible="{Binding Mood, Converter={StaticResource StringNotNullOrEmptyConverter}}"  -->

        <!-- State -->
        <Label Text="{Binding State}"
               FontSize="12"
               Opacity="0.7" />

        <!-- Text -->
        <Label Text="{Binding Text}"
               FontSize="16" />

    </VerticalStackLayout>
       

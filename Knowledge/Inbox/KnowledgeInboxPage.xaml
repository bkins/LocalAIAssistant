       <CollectionView ItemsSource="{Binding Items}"
                SelectionMode="Single"
                SelectedItem="{Binding SelectedItem, Mode=TwoWay}">

    <CollectionView.ItemTemplate>
        <DataTemplate>

            <!-- RESTORE: Swipe container -->
            <SwipeView>

                <!-- KEEP: your existing SwipeItems (left/right) -->
                <SwipeView.RightItems>
                    <SwipeItems Mode="Reveal">
                        <SwipeItem Text="Delete"
                                   BackgroundColor="Red"
                                   Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                     Path=BindingContext.DeleteCommand}"
                                   CommandParameter="{Binding .}" />
                    </SwipeItems>
                </SwipeView.RightItems>

                <SwipeView.Content>

                    <!-- RESTORE: Card frame -->
                    <Frame Padding="12"
                           Margin="8,4"
                           CornerRadius="12"
                           HasShadow="True">

                        <!-- ENRICHED CONTENT -->
                        <Grid RowDefinitions="Auto,Auto"
                              ColumnDefinitions="*,Auto"
                              RowSpacing="4">

                            <!-- Title -->
                            <Label Grid.Row="0"
                                   Grid.Column="0"
                                   Text="{Binding Title}"
                                   FontAttributes="Bold"
                                   LineBreakMode="TailTruncation" />

                            <!-- Status indicator (only if Status != Active) -->
                            <Frame Grid.Row="0"
                                   Grid.Column="1"
                                   Padding="6,2"
                                   CornerRadius="10"
                                   HasShadow="False"
                                   BorderColor="Gray"
                                   BackgroundColor="Transparent"
                                   IsVisible="False">

                                <Label Text="{Binding Status,
                                                     Converter={StaticResource StatusToTextConverter}}"
                                       FontSize="11" />

                                <Frame.Triggers>
                                    <DataTrigger TargetType="Frame"
                                                 Binding="{Binding Status}"
                                                 Value="Active">
                                        <Setter Property="IsVisible" Value="False" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Frame"
                                                 Binding="{Binding Status}"
                                                 Value="Archived">
                                        <Setter Property="IsVisible" Value="True" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Frame"
                                                 Binding="{Binding Status}"
                                                 Value="Deleted">
                                        <Setter Property="IsVisible" Value="True" />
                                    </DataTrigger>
                                </Frame.Triggers>
                            </Frame>

                            <!-- Tags -->
                            <Label Grid.Row="1"
                                   Grid.Column="0"
                                   Grid.ColumnSpan="2"
                                   Text="{Binding Tags,
                                                  Converter={StaticResource TagsToTextConverter}}"
                                   FontSize="12"
                                   Opacity="0.75" />
                        </Grid>

                    </Frame>
                </SwipeView.Content>
            </SwipeView>

        </DataTemplate>
    </CollectionView.ItemTemplate>
</CollectionView>

        

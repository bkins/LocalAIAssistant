<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="LocalAIAssistant.Knowledge.Inbox.KnowledgeInboxPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:converters1="clr-namespace:LocalAIAssistant.Converters"
    xmlns:inbox="clr-namespace:LocalAIAssistant.Knowledge.Inbox"
    Title="Knowledge">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters1:TagsToTextConverter            x:Key="TagsToTextConverter" />
            <converters1:IntGreaterThanZeroConverter    x:Key="IntGtZero" />
            <converters1:NullToBoolConverter            x:Key="NullToBool" />
            <converters1:KnowledgeKindToColorConverter  x:Key="KindToColorConverter" />
            <converters1:InverseBoolConverter           x:Key="InverseBool" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <VerticalStackLayout Grid.Row="0">

            <!-- Offline banner -->
            <Border
                Padding="10,6"
                BackgroundColor="#553300"
                IsVisible="{Binding IsOffline}">
                <Label Text="Offline — showing last synced data and queued items"
                       FontSize="12"
                       TextColor="#FFCC88"
                       HorizontalOptions="Center" />
            </Border>

            <!-- Error banner -->
            <Border
                Padding="10,6"
                BackgroundColor="#4D0000"
                IsVisible="{Binding HasError}">
                <Label Text="{Binding ErrorMessage}"
                       FontSize="12"
                       TextColor="#FF8888"
                       HorizontalOptions="Center" />
            </Border>

            <!-- Type filter chips -->
            <ScrollView Orientation="Horizontal" HeightRequest="44" Padding="8,4">
                <HorizontalStackLayout BindableLayout.ItemsSource="{Binding TypeFilters}"
                                       Spacing="6">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="inbox:FilterChip">
                            <Border Padding="10,6"
                                    StrokeShape="RoundRectangle 14"
                                    StrokeThickness="1">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="BackgroundColor" Value="#2A4A80" />
                                        <Setter Property="Stroke" Value="#5588CC" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="False">
                                        <Setter Property="BackgroundColor" Value="#1E1E1E" />
                                        <Setter Property="Stroke" Value="#444" />
                                    </DataTrigger>
                                </Border.Triggers>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                          Path=BindingContext.SelectTypeFilterCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Label Text="{Binding Label}"
                                       FontSize="13"
                                       TextColor="White" />
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </HorizontalStackLayout>
            </ScrollView>

            <!-- Workspace filter chips (hidden when no workspace data) -->
            <ScrollView Orientation="Horizontal" HeightRequest="36" Padding="8,0,8,4"
                        IsVisible="{Binding HasMultipleWorkspaces}">
                <HorizontalStackLayout BindableLayout.ItemsSource="{Binding WorkspaceFilters}"
                                       Spacing="6">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="inbox:FilterChip">
                            <Border Padding="8,4"
                                    StrokeShape="RoundRectangle 10"
                                    StrokeThickness="1">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="BackgroundColor" Value="#1E3A2A" />
                                        <Setter Property="Stroke" Value="#44AA66" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="False">
                                        <Setter Property="BackgroundColor" Value="#1A1A1A" />
                                        <Setter Property="Stroke" Value="#333" />
                                    </DataTrigger>
                                </Border.Triggers>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                          Path=BindingContext.SelectWorkspaceFilterCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Label Text="{Binding Label}"
                                       FontSize="12"
                                       TextColor="#AACCAA" />
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </HorizontalStackLayout>
            </ScrollView>

        </VerticalStackLayout>

        <CollectionView
            Grid.Row="1"
            AutomationId="InboxList"
            ItemsSource="{Binding GroupedItems}"
            IsGrouped="True"
            SelectionMode="Single"
            SelectedItem="{Binding SelectedItem}">

            <CollectionView.GroupHeaderTemplate>
                <DataTemplate>
                    <Border Padding="12,6"
                            Margin="6,10,6,2"
                            BackgroundColor="#1E1E1E"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 6">
                        <Label Text="{Binding DomainLabel}"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{Binding Kind, Converter={StaticResource KindToColorConverter}}" />
                    </Border>
                </DataTemplate>
            </CollectionView.GroupHeaderTemplate>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <SwipeView>

                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem
                                    Text="Archive"
                                    BackgroundColor="#883333"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                      Path=BindingContext.ArchiveCommand}"
                                    CommandParameter="{Binding .}" />
                            </SwipeItems>
                        </SwipeView.RightItems>

                        <Border
                            Padding="12"
                            Margin="6"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 8">

                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding IsQueued}" Value="True">
                                    <Setter Property="Stroke" Value="#664400" />
                                    <Setter Property="BackgroundColor" Value="#1A110500" />
                                </DataTrigger>
                                <DataTrigger TargetType="Border" Binding="{Binding IsQueued}" Value="False">
                                    <Setter Property="Stroke" Value="#333" />
                                </DataTrigger>
                            </Border.Triggers>

                            <VerticalStackLayout Spacing="6">

                                <Label
                                    Text="{Binding Title}"
                                    FontSize="16"
                                    LineBreakMode="WordWrap" />

                                <HorizontalStackLayout Spacing="8">

                                    <!-- Workspace badge -->
                                    <Border
                                        Padding="4,2"
                                        BackgroundColor="#1A2A3A"
                                        StrokeShape="RoundRectangle 4"
                                        StrokeThickness="1"
                                        Stroke="#2A4A6A"
                                        IsVisible="{Binding Workspace, Converter={StaticResource NullToBool}}">
                                        <Label
                                            Text="{Binding Workspace}"
                                            FontSize="11"
                                            TextColor="#88AACC" />
                                    </Border>

                                    <Label
                                        Text="{Binding Tags, Converter={StaticResource TagsToTextConverter}}"
                                        FontSize="12"
                                        TextColor="{AppThemeBinding Light=#666, Dark=#AAA}"
                                        IsVisible="{Binding Tags.Count, Converter={StaticResource IntGtZero}}" />

                                    <Label
                                        Text="{Binding Mood}"
                                        FontSize="12"
                                        TextColor="{AppThemeBinding Light=#666, Dark=#AAA}"
                                        IsVisible="{Binding Mood, Converter={StaticResource NullToBool}}" />

                                    <Label
                                        Text="{Binding MoodScore}"
                                        FontSize="12"
                                        TextColor="{AppThemeBinding Light=#666, Dark=#AAA}"
                                        IsVisible="{Binding MoodScore, Converter={StaticResource NullToBool}}" />

                                    <Label
                                        Text="Edited"
                                        FontSize="12"
                                        TextColor="#CC8844"
                                        IsVisible="{Binding IsEdited}" />

                                    <!-- Queued badge -->
                                    <Border
                                        Padding="4,2"
                                        BackgroundColor="#664400"
                                        StrokeShape="RoundRectangle 4"
                                        IsVisible="{Binding IsQueued}">
                                        <Label
                                            Text="Queued"
                                            FontSize="11"
                                            TextColor="#FFCC88" />
                                    </Border>

                                </HorizontalStackLayout>

                            </VerticalStackLayout>
                        </Border>

                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" 
                                     VerticalOptions="Center"
                                     Padding="20"
                                     Spacing="12">
                    <!-- Loading state: Spinner + text -->
                    <ActivityIndicator IsRunning="{Binding IsLoading}"
                                       IsVisible="{Binding IsLoading}"
                                       HorizontalOptions="Center"
                                       WidthRequest="36"
                                       HeightRequest="36"
                                       Color="#5588CC" />
                    <Label Text="Loading inbox..."
                           IsVisible="{Binding IsLoading}"
                           HorizontalOptions="Center"
                           FontSize="14"
                           TextColor="{AppThemeBinding Light=#666, Dark=#AAA}"/>

                    <!-- Empty state: Text when loading completes and no items exist -->
                    <Label Text="No items in your inbox"
                           IsVisible="{Binding IsLoading, Converter={StaticResource InverseBool}}"
                           HorizontalOptions="Center"
                           FontSize="16"
                           TextColor="{AppThemeBinding Light=#666, Dark=#AAA}"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>

    </Grid>
</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="LocalAIAssistant.Knowledge.Inbox.KnowledgeInboxPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Knowledge">

    

    <!-- <Grid RowDefinitions="Auto,*"> -->
    <Grid RowDefinitions="*">
        <!-- Loading indicator -->
        <!-- <ActivityIndicator Grid.Row="0" -->
        <!--                    IsRunning="{Binding IsLoading}" -->
        <!--                    IsVisible="{Binding IsLoading}" -->
        <!--                    Margin="12" /> -->

        <!-- Knowledge list -->
        <CollectionView
            ItemsSource="{Binding Items}"
            SelectionMode="None">

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <SwipeView>

                        <!-- Swipe actions -->
                        <SwipeView.RightItems>
                            <SwipeItems Mode="Reveal">
                                <SwipeItem
                                    Text="Archive"
                                    BackgroundColor="Red"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                              Path=BindingContext.ArchiveCommand}"
                                    CommandParameter="{Binding .}" />
                            </SwipeItems>
                        </SwipeView.RightItems>

                        <!-- Visual root of the item -->
                        <Border Stroke="Gray"
                                StrokeThickness="1"
                                Padding="12"
                                Margin="8"
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">

                            <!-- Existing layout -->
                            <VerticalStackLayout Spacing="4">

                                <Label Text="{Binding CreatedAtLocal,
                                           StringFormat='{0:MMM d, yyyy h:mm tt}'}"
                                       FontSize="12"
                                       TextColor="Gray" />
                                <Label Text="{Binding Kind}"/>
                                <Label Text="{Binding Title}"
                                       FontAttributes="Bold"
                                       LineBreakMode="TailTruncation" />


                            </VerticalStackLayout>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}
                                            , Path=BindingContext.OpenCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                        </Border>

                    </SwipeView>

                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:LocalAIAssistant.Data.Models"
             xmlns:android="Microsoft.Maui.Controls.PlatformConfiguration"
             xmlns:models="clr-namespace:LocalAIAssistant.Data.Models"
             x:Class="LocalAIAssistant.MainPage"
             BackgroundColor="White"
             Title="Local AI Assistant">

    <Grid RowDefinitions="Auto,*,Auto"
          Padding="10"
          RowSpacing="10">
        
        <ActivityIndicator Grid.Row="1"
            IsRunning="{Binding IsBusy}" 
                           IsVisible="{Binding IsBusy}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           Color="DodgerBlue"
                           HeightRequest="40"
                           WidthRequest="40"/>
        
        <!-- Header -->
        <Label Grid.Row="0"
               Text="Ask the AI"
               FontSize="28"
               HorizontalOptions="Center"
               TextColor="Black"
               FontAttributes="Bold" />

        <!-- Chat messages -->
        <CollectionView Grid.Row="1"
                        x:Name="MessagesView"
                        ItemsSource="{Binding Messages}"
                        VerticalOptions="FillAndExpand"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Message">
                    <Frame Margin="6"
                           BackgroundColor="{Binding Sender, Converter={StaticResource SenderToColorConverter}}"
                           CornerRadius="12"
                           Padding="10"
                           HasShadow="False">
                        <Label Text="{Binding Content}"
                               TextColor="Black"
                               FontSize="16" />
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Input area -->
        <Grid Grid.Row="2"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="10">
            <!--Keyboard="Chat" -->
            <Editor x:Name="PromptEditor"
                    Grid.Column="0"
                    Placeholder="Type your message..."
                    Text="{Binding PromptText}"
                    AutoSize="TextChanges"
                    Completed="PromptEditor_Completed"
                    TextColor="Black"
                    BackgroundColor="#F0F0F0"
                    FontSize="16"
                    HorizontalOptions="FillAndExpand"/>
                    
            <Button Grid.Column="1"
                    Text="Send"
                    Command="{Binding SendPromptCommand}"
                    FontSize="16"
                    Padding="10,0"
                    VerticalOptions="End" />

        </Grid>

    </Grid>

</ContentPage>



<Shell
    x:Class="LocalAIAssistant.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:LocalAIAssistant.Views"
    xmlns:viewModels="clr-namespace:LocalAIAssistant.ViewModels"
    xmlns:inbox="clr-namespace:LocalAIAssistant.Knowledge.Inbox"
    xmlns:local="clr-namespace:LocalAIAssistant.Core.Environment"
    x:DataType="viewModels:AppShellMasterViewModel"
    Title="LocalAIAssistant"
    x:Name="AppShellRoot"

    BackgroundColor="{StaticResource SurfaceColor}"
    Shell.ForegroundColor="{StaticResource PrimaryTextColor}"
    Shell.TitleColor="{StaticResource PrimaryTextColor}"
    Shell.TabBarBackgroundColor="{StaticResource AppBackgroundColor}"
    Shell.TabBarForegroundColor="{StaticResource PrimaryTextColor}"
    Shell.TabBarUnselectedColor="{StaticResource SecondaryTextColor}">

    <Shell.TitleView>
        <!--
            Column layout:
              0  — App title
              1  — Environment name
              2  — API status dot
              3  — Usage indicator (new)
              4  — Spacer
              5  — Offline queue badge
              
              TODO: Add a row to the grid and move the environment name and usage indicator below the title so 
                    everything is visible on smaller device (e.g. a phone).
        -->
        <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto"
              Padding="8"
              VerticalOptions="Center">

            <!-- Title -->
            <Label Grid.Column="0"
                   Text="Cognitive Assistant"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="{x:Static local:EnvironmentTheme.PrimaryColor}"
                   VerticalOptions="Center" />

            <!-- Environment Name -->
            <Label Grid.Column="1"
                   Text="{Binding EnvironmentName}"
                   FontSize="10"
                   TextColor="Orange"
                   Margin="8,0"
                   VerticalOptions="Center"/>

            <!-- API Status Dot -->
            <Border Grid.Column="2"
                    WidthRequest="10"
                    HeightRequest="10"
                    BackgroundColor="{Binding StatusColor}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 5"
                    VerticalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding CheckStatusCommand}" />
                </Border.GestureRecognizers>
            </Border>

            <!-- Usage Indicator -->
            <!--
                Shows "847 req · 42k tok" when data is available.
                Colour: gray (normal) → orange (>70%) → red (>90%).
                Tapping refreshes usage on demand.
                Hidden until the first Groq call has been made.
            -->
            <Label Grid.Column="3"
                   Text="{Binding UsageViewModel.HeaderSummary}"
                   TextColor="{Binding UsageViewModel.HeaderColor}"
                   FontSize="10"
                   Margin="8,0,0,0"
                   VerticalOptions="Center"
                   IsVisible="{Binding UsageViewModel.HasData}">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding UsageViewModel.RefreshCommand}" />
                </Label.GestureRecognizers>
            </Label>

            <!-- Spacer -->
            <BoxView Grid.Column="4"
                     BackgroundColor="Transparent"/>

            <!-- Offline Queue Badge -->
            <Frame Grid.Column="5"
                   BackgroundColor="Red"
                   Padding="4"
                   CornerRadius="20"
                   HasShadow="False"
                   IsVisible="{Binding PendingQueueCount, Converter={StaticResource IntGreaterThanZeroConverter}}"
                   VerticalOptions="Center">
                <Label Text="{Binding PendingQueueCount}"
                       TextColor="White"
                       FontSize="10"/>
            </Frame>

        </Grid>
    </Shell.TitleView>

    <TabBar>
        <Tab Title="🏚️">
            <ShellContent ContentTemplate="{DataTemplate views:MainPage}"/>
        </Tab>
        <Tab Title="🧠">
            <ShellContent x:Name="MemoryShellContent"
                          ContentTemplate="{DataTemplate views:MemoryManagementPage}"/>
        </Tab>
        <Tab Title="📜🔴"
             IsVisible="{Binding Path=BindingContext.AppShellViewModel.HasErrorsInLogs
                       , Source={x:Reference AppShellRoot}}">
            <ShellContent ContentTemplate="{DataTemplate views:LogsPage}" />
        </Tab>
        <Tab Title="📜"
             IsVisible="{Binding Path=BindingContext.AppShellViewModel.HasNoErrorsInLogs
                       , Source={x:Reference AppShellRoot}}">
            <ShellContent ContentTemplate="{DataTemplate views:LogsPage}" />
        </Tab>
        <Tab Title="🛠️">
            <ShellContent Title="Settings"
                          ContentTemplate="{DataTemplate views:SettingsPage}" />
        </Tab>
    </TabBar>

    <ShellContent Route="knowledge"
                  ContentTemplate="{DataTemplate inbox:KnowledgeInboxPage}" />

</Shell>

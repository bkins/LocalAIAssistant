<Shell
    x:Class="LocalAIAssistant.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:LocalAIAssistant.Views"
    xmlns:viewModels="clr-namespace:LocalAIAssistant.ViewModels"
    xmlns:inbox="clr-namespace:LocalAIAssistant.Knowledge.Inbox"
    xmlns:local="clr-namespace:LocalAIAssistant.Core.Environment"
    x:DataType="viewModels:AppShellMasterViewModel"
    Title="LocalAIAssistant"
    x:Name="AppShellRoot"
    FlyoutBehavior="Disabled"

    BackgroundColor="{StaticResource SurfaceColor}"
    Shell.ForegroundColor="{StaticResource PrimaryTextColor}"
    Shell.TitleColor="{StaticResource PrimaryTextColor}"
    Shell.TabBarBackgroundColor="{StaticResource AppBackgroundColor}"
    Shell.TabBarForegroundColor="{StaticResource PrimaryTextColor}"
    Shell.TabBarUnselectedColor="{StaticResource SecondaryTextColor}">

    <Shell.TitleView>
        <!--
            Column layout:
              0  — App title
              1  — Environment name
              2  — API status dot
              3  — Usage indicator (new)
              4  — Spacer
              5  — Offline queue badge
              
              TODO: Add a row to the grid and move the environment name and usage indicator below the title so 
                    everything is visible on smaller device (e.g. a phone).
        -->
        <Grid x:Name="TitleViewGrid"
              ColumnDefinitions="Auto,Auto,*,Auto"
              RowDefinitions="Auto,Auto"
              Padding="8,4"
              VerticalOptions="Center">

            <!-- Title -->
            <Label Grid.Column="0"
                   Grid.Row="0"
                   AutomationId="AppTitle"
                   Text="Cognitive Assistant"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="{x:Static local:EnvironmentTheme.PrimaryColor}"
                   VerticalOptions="Center" 
                   Margin="0,0,8,0"/>

            <!-- API Status Dot -->
            <Border Grid.Column="1"
                    Grid.Row="0"
                    WidthRequest="10"
                    HeightRequest="10"
                    BackgroundColor="{Binding StatusColor}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 5"
                    VerticalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding CheckStatusCommand}" />
                </Border.GestureRecognizers>
            </Border>
            
            <!-- Environment Name (Row 1 — secondary info) -->
            <Label Grid.Column="0"
                   Grid.Row="1"
                   Text="{Binding EnvironmentName}"
                   FontSize="10"
                   TextColor="Orange"
                   Margin="0,0,12,0"
                   VerticalOptions="Center"/>

            <!-- Usage Indicator -->
            <Label Grid.Column="1"
                   Grid.Row="1"
                   Grid.ColumnSpan="2"
                   Text="{Binding UsageViewModel.HeaderSummary}"
                   TextColor="{Binding UsageViewModel.HeaderColor}"
                   FontSize="10"
                   Margin="8,0,0,0"
                   VerticalOptions="Center"
                   IsVisible="{Binding UsageViewModel.HasData}">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding UsageViewModel.RefreshCommand}" />
                </Label.GestureRecognizers>
            </Label>

            <!-- Spacer -->
            <BoxView Grid.Column="2"
                     Grid.Row="0"
                     BackgroundColor="Transparent"/>

            <!-- Badges: memory confirmation + offline queue -->
            <HorizontalStackLayout x:Name="BadgesLayout"
                                   Grid.Column="3"
                                   Grid.Row="0"
                                   Spacing="4"
                                   VerticalOptions="Center">

                 <!-- Memory confirmation badge — tapping navigates to the Memory tab -->
                <Frame x:Name="MemoryBadgeFrame"
                       AutomationId="MemoryBadgeFrame"
                       BackgroundColor="Transparent"
                       Padding="4,2"
                       CornerRadius="20"
                       HasShadow="False">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToMemoryCommand}" />
                    </Frame.GestureRecognizers>
                    <HorizontalStackLayout Spacing="2">
                        <Label x:Name="MemoryBadgeIcon"
                               Text=""
                               FontSize="9"
                               VerticalOptions="Center" />
                        <Label x:Name="MemoryBadgeLabel"
                               Text=""
                               TextColor="White"
                               FontSize="10"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Frame>

                <!-- Offline Queue Badge -->
                <Frame BackgroundColor="Red"
                       Padding="4"
                       CornerRadius="20"
                       HasShadow="False"
                       AutomationId="OfflineQueueBadgeFrame"
                       IsVisible="{Binding PendingQueueCount, Converter={StaticResource IntGreaterThanZeroConverter}}">
                    <Label Text="{Binding PendingQueueCount}"
                           AutomationId="OfflineQueueBadgeLabel"
                           TextColor="White"
                           FontSize="10"/>
                </Frame>

            </HorizontalStackLayout>

        </Grid>
    </Shell.TitleView>

    <TabBar>
        <Tab Title="Chat" AutomationId="ChatTabItem">
            <ShellContent Route="Chat" ContentTemplate="{DataTemplate views:MainPage}"/>
        </Tab>
        <Tab Title="Chats" AutomationId="ChatsTabItem">
            <ShellContent ContentTemplate="{DataTemplate views:ConversationsPage}"/>
        </Tab>
        <Tab Title="Inbox" AutomationId="InboxTabItem">
            <ShellContent ContentTemplate="{DataTemplate inbox:KnowledgeInboxPage}"/>
        </Tab>
        <Tab Title="Actions" AutomationId="ActionsTabItem">
            <ShellContent Route="ActionDirectory" 
                           ContentTemplate="{DataTemplate views:ActionDirectoryPage}"/>
        </Tab>
        <Tab Title="Memory" x:Name="MemoryTab" AutomationId="MemoryTabItem">
            <ShellContent x:Name="MemoryShellContent"
                           Route="Memory"
                           ContentTemplate="{DataTemplate views:MemoryManagementPage}"/>
        </Tab>
        <Tab Title="Logs" AutomationId="LogsTabItem">
            <ShellContent ContentTemplate="{DataTemplate views:LogsPage}" />
        </Tab>
        <Tab Title="Settings" AutomationId="SettingsTabItem">
            <ShellContent Title="Settings"
                           ContentTemplate="{DataTemplate views:SettingsPage}" />
        </Tab>
    </TabBar>

</Shell>

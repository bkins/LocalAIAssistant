<!--                 FontAttributes="Bold" -->
<!--                 FontSize="12" -->
<!--                 TextColor="#FFCCCC" -->
<!--                 HorizontalOptions="Center" -->
<!--                 HorizontalTextAlignment="Center" /> -->
<!--         </Border> -->
    </Shell.TitleView>

    <!-- <Shell.TitleView> -->
    <!--      -->
    <!--     <HorizontalStackLayout Padding="8"  -->
    <!--                            Spacing="8"  -->
    <!--                            HorizontalOptions="Center"  -->
    <!--                            VerticalOptions="Center"> -->
    <!--          -->

<Shell
    x:Class="LocalAIAssistant.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:LocalAIAssistant.Views"
    xmlns:viewModels="clr-namespace:LocalAIAssistant.ViewModels"
    xmlns:inbox="clr-namespace:LocalAIAssistant.Knowledge.Inbox"
    x:DataType="viewModels:AppShellMasterViewModel"
    Title="LocalAIAssistant"
    x:Name="AppShellRoot"
    
    BackgroundColor="{StaticResource SurfaceColor}"
    Shell.ForegroundColor="{StaticResource PrimaryTextColor}"
    Shell.TitleColor="{StaticResource PrimaryTextColor}"
    Shell.TabBarBackgroundColor="{StaticResource AppBackgroundColor}"
    Shell.TabBarForegroundColor="{StaticResource PrimaryTextColor}"
    Shell.TabBarUnselectedColor="{StaticResource SecondaryTextColor}"
    >
    <Shell.TitleView>
        <HorizontalStackLayout Padding="8"
                               Spacing="8"
                               HorizontalOptions="Center"
                               VerticalOptions="Center">
        
            <Label Text="Cognitive Assistant"
                   FontSize="21"
                   FontAttributes="Bold"
                   TextColor="{StaticResource PrimaryTextColor}" />
        
            <Label Text="{Binding EnvironmentName}"
                   FontSize="10"
                   TextColor="Orange"
                   HorizontalOptions="End"
                   Margin="8"/>
            
            <Border
                WidthRequest="10"
                HeightRequest="10"
                BackgroundColor="{Binding StatusColor}"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 5">
                <Border.Shadow>
                    <Shadow Brush="Black"
                            Offset="10,10"
                            Radius="10"
                            Opacity="0.4" />
                </Border.Shadow>
            </Border>
        
        
        </HorizontalStackLayout>
        <!-- IsVisible="{Binding IsOffline}" -->
<!--         <Border -->
<!--             IsVisible="True" -->
<!--             BackgroundColor="#332222" -->
<!--             Stroke="#884444" -->
<!--             StrokeThickness="1" -->
